PORT=3000
NODE_ENV=development

# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/salao_chatbot
# Para Railway, a variável DATABASE_URL é injetada automaticamente

# Evolution API — WhatsApp
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=salao-principal

# OpenAI
OPENAI_API_KEY=sk-...

# Configurações do salão (podem ir pro banco depois)
SALON_NAME=Salão Bella Vista
SALON_PHONE=11999998888
SALON_ADDRESS=Rua das Flores, 123 - Centro
SALON_INSTAGRAM=@bellavista_salao

# Webhook — URL pública deste backend (ngrok em dev, Railway em prod)
WEBHOOK_URL=https://seu-backend.up.railway.app
